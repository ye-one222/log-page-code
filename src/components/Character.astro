---
import type { Persona } from '../config/personas';

/**
 * 페르소나별 2D 캐릭터 (플레이스홀더).
 * 추후 Three.js 3D 캐릭터로 교체할 때 이 컴포넌트만 갈아끼우면 된다 —
 * PersonaHero는 "회전 시 캐릭터가 바뀐다"는 것만 알고, 그리는 방법은 모른다.
 *
 * 새 페르소나 추가 시: 아래에 액세서리 분기 하나만 추가.
 */
interface Props {
  persona: Persona;
}

const { persona } = Astro.props;
const cloth = persona.color.main;
const ink = '#2c2c2a';
---

<svg viewBox="0 0 200 235" width="196" height="230" aria-hidden="true">
  <rect x="80" y="180" width="14" height="42" rx="7" fill="#3b3b3b"></rect>
  <rect x="106" y="180" width="14" height="42" rx="7" fill="#3b3b3b"></rect>
  <rect x="52" y="122" width="20" height="56" rx="10" fill={cloth}></rect>
  <rect x="128" y="122" width="20" height="56" rx="10" fill={cloth}></rect>
  <rect x="62" y="112" width="76" height="80" rx="24" fill={cloth}></rect>
  <circle cx="100" cy="70" r="38" fill="#f2c9a3"></circle>
  <path d="M64 62 A38 38 0 0 1 136 62 Z" fill={ink}></path>
  <circle cx="86" cy="74" r="4" fill={ink}></circle>
  <circle cx="114" cy="74" r="4" fill={ink}></circle>
  <path
    d="M90 88 Q100 96 110 88"
    stroke={ink}
    stroke-width="3"
    fill="none"
    stroke-linecap="round"></path>

  {
    persona.id === 'researcher' && (
      <>
        <circle cx="86" cy="74" r="11" fill="none" stroke={ink} stroke-width="2.5" />
        <circle cx="114" cy="74" r="11" fill="none" stroke={ink} stroke-width="2.5" />
        <line x1="97" y1="74" x2="103" y2="74" stroke={ink} stroke-width="2.5" />
        <g transform="rotate(8 137 160)">
          <rect x="120" y="139" width="34" height="42" rx="3" fill="#ffffff" stroke="#b4b2a9" />
          <line x1="126" y1="149" x2="148" y2="149" stroke="#b4b2a9" stroke-width="2" />
          <line x1="126" y1="157" x2="148" y2="157" stroke="#b4b2a9" stroke-width="2" />
          <line x1="126" y1="165" x2="142" y2="165" stroke="#b4b2a9" stroke-width="2" />
        </g>
      </>
    )
  }

  {
    persona.id === 'creator' && (
      <>
        <rect x="72" y="138" width="56" height="38" rx="8" fill={ink} />
        <rect x="88" y="130" width="24" height="10" rx="3" fill={ink} />
        <circle cx="100" cy="157" r="12" fill="#5f5e5a" stroke="#f1efe8" stroke-width="2" />
        <circle cx="100" cy="157" r="5" fill={ink} />
        <circle cx="119" cy="146" r="3" fill="#f09595" />
      </>
    )
  }

  {
    persona.id === 'reader' && (
      <>
        <path d="M64 140 L98 148 L98 184 L64 176 Z" fill="#ffffff" stroke="#b4b2a9" />
        <path d="M136 140 L102 148 L102 184 L136 176 Z" fill="#f1efe8" stroke="#b4b2a9" />
        <line x1="100" y1="148" x2="100" y2="184" stroke="#b4b2a9" stroke-width="2" />
      </>
    )
  }

  {
    persona.id === 'musician' && (
      <>
        <line
          x1="58"
          y1="116"
          x2="122"
          y2="154"
          stroke="#5c3a21"
          stroke-width="7"
          stroke-linecap="round"
        />
        <ellipse
          cx="130"
          cy="161"
          rx="24"
          ry="19"
          fill="#8b5a2b"
          transform="rotate(20 130 161)"
        />
        <circle cx="126" cy="158" r="6" fill="#3b2314" />
        <line x1="62" y1="119" x2="126" y2="157" stroke="#e8d9b0" stroke-width="1.5" />
      </>
    )
  }
</svg>
