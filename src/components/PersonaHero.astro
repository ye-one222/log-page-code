---
import PostCard from './PostCard.astro';
import { PERSONAS, type PersonaId } from '../config/personas';
import { NAV, SITE } from '../config/site';
import type { FeedItem } from '../lib/posts';

/**
 * 홈 화면: 회전 버튼으로 페르소나를 전환하는 히어로 + 페르소나별 최신 글 피드.
 * 캐릭터는 Three.js 복셀 캐릭터(src/lib/character3d) — 캔버스 하나에서
 * 스킨을 갈아입는 방식이라 페르소나별 마크업은 텍스트/피드만 존재한다.
 */
interface Props {
  feeds: Record<PersonaId, FeedItem[]>;
}

const { feeds } = Astro.props;

function sectionHref(persona: (typeof PERSONAS)[number]): string {
  return NAV.find((n) => n.key === persona.nav)?.href ?? '/';
}
---

<section class="hero">
  <div class="copy-col">
    {
      PERSONAS.map((p, i) => (
        <div class="copy" data-persona={p.id} hidden={i !== 0}>
          <span class="pill" style={`background: ${p.color.soft}; color: ${p.color.deep}`}>
            {p.badge}
          </span>
          <h1>안녕하세요, {SITE.author}입니다</h1>
          <p class="role">{p.role}</p>
          <p class="tagline">{p.tagline}</p>
        </div>
      ))
    }
    <div class="actions">
      <a class="btn" href="/about/">About me</a>
    </div>
  </div>

  <div class="stage-col">
    <div class="ring" id="persona-ring" style={`border-color: ${PERSONAS[0].color.main}`}>
      <canvas id="persona-canvas" width="230" height="230" aria-hidden="true"></canvas>
    </div>
    <div class="dots" aria-hidden="true">
      {
        PERSONAS.map((p, i) => (
          <span
            class:list={['dot', { on: i === 0 }]}
            data-persona={p.id}
            data-color={p.color.main}
            data-nav={p.nav}
          />
        ))
      }
    </div>
    <button class="btn" id="persona-rotate" type="button"> 회전 — 다른 나 만나기 </button>
  </div>
</section>

<section class="feeds">
  {
    PERSONAS.map((p, i) => (
      <div class="feed" data-persona={p.id} hidden={i !== 0}>
        <div class="feed-head">
          <h2>{p.name}의 글</h2>
          <a class="more" href={sectionHref(p)}>
            전체 보기 →
          </a>
        </div>
        {feeds[p.id].length > 0 ? (
          <div class="grid">
            {feeds[p.id].map((item) => (
              <PostCard item={item} />
            ))}
          </div>
        ) : (
          <p class="empty">아직 글이 없어요. 곧 채워집니다.</p>
        )}
      </div>
    ))
  }
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 40px;
    padding: 56px 0 40px;
    flex-wrap: wrap;
  }

  .copy-col {
    flex: 1;
    min-width: 280px;
  }

  h1 {
    font-size: 28px;
    margin: 16px 0 8px;
  }

  .role {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .tagline {
    font-size: 15px;
    color: var(--text-2);
    min-height: 52px;
  }

  .actions {
    margin-top: 20px;
  }

  .stage-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
    margin: 0 auto;
  }

  .ring {
    width: 230px;
    height: 230px;
    border-radius: 50%;
    background: var(--surface);
    border: 3px solid transparent;
    overflow: hidden;
    transition: border-color 0.3s ease;
  }

  .ring canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .dots {
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border-strong);
    transition: background 0.3s ease;
  }

  .feeds {
    padding-bottom: 20px;
  }

  .feed-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .feed-head h2 {
    font-size: 19px;
  }

  .more {
    font-size: 13px;
    color: var(--text-3);
  }

  .more:hover {
    color: var(--text);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .empty {
    font-size: 14px;
    color: var(--text-3);
  }
</style>

<script>
  import { createPersonaCharacter } from '../lib/character3d';
  import type { PersonaId } from '../config/personas';

  const ring = document.getElementById('persona-ring')!;
  const canvas = document.getElementById('persona-canvas') as HTMLCanvasElement;
  const rotateBtn = document.getElementById('persona-rotate')!;
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.dot'));
  const navLinks = Array.from(document.querySelectorAll<HTMLElement>('[data-nav-key]'));
  const blocks = Array.from(
    document.querySelectorAll<HTMLElement>('.copy[data-persona], .feed[data-persona]'),
  );
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // WebGL 미지원 환경에서는 캐릭터 없이 텍스트 전환만 동작한다
  let character: ReturnType<typeof createPersonaCharacter> | null = null;
  try {
    character = createPersonaCharacter(canvas, dots[0].dataset.persona as PersonaId);
  } catch (error) {
    console.error('3D 캐릭터 초기화 실패:', error);
    canvas.hidden = true;
  }

  let index = 0;
  let busy = false;

  function show(i: number) {
    const dot = dots[i];
    const id = dot.dataset.persona;
    for (const block of blocks) block.hidden = block.dataset.persona !== id;
    for (const d of dots) {
      d.classList.toggle('on', d === dot);
      d.style.background = d === dot ? (d.dataset.color ?? '') : '';
    }
    ring.style.borderColor = dot.dataset.color ?? '';
    for (const link of navLinks) {
      link.classList.toggle('active', link.dataset.navKey === dot.dataset.nav);
    }
  }

  rotateBtn.addEventListener('click', () => {
    if (busy) return;
    const next = (index + 1) % dots.length;
    const id = dots[next].dataset.persona as PersonaId;

    if (!character || reduceMotion) {
      index = next;
      show(index);
      character?.setPersona(id);
      return;
    }

    busy = true;
    character
      .spin(id, () => {
        index = next;
        show(index);
      })
      .finally(() => {
        busy = false;
      });
  });

  show(0);
</script>
