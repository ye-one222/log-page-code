---
import PostCard from './PostCard.astro';
import { PERSONAS, type PersonaId } from '../config/personas';
import { NAV, SITE } from '../config/site';
import type { FeedItem } from '../lib/posts';

/**
 * 홈 화면: "페르소나의 방" 3D 무대 + 페르소나별 최신 글 피드.
 * 방(src/lib/room3d)의 구역을 탭하거나 도트/회전 버튼을 누르면
 * 캐릭터가 그 구역으로 걸어가고 텍스트/피드가 함께 전환된다.
 * 정보(인사말/피드)는 전부 DOM — 3D는 무대일 뿐이다. (design/persona-room/design.md)
 */
interface Props {
  feeds: Record<PersonaId, FeedItem[]>;
}

const { feeds } = Astro.props;

function sectionHref(persona: (typeof PERSONAS)[number]): string {
  return NAV.find((n) => n.key === persona.nav)?.href ?? '/';
}
---

<section class="hero">
  <div class="copy-col">
    {
      PERSONAS.map((p, i) => (
        <div class="copy" data-persona={p.id} hidden={i !== 0}>
          <span class="pill" style={`background: ${p.color.soft}; color: ${p.color.deep}`}>
            {p.badge}
          </span>
          <h1>안녕하세요, {SITE.author}입니다</h1>
          <p class="role">{p.role}</p>
          <p class="tagline">{p.tagline}</p>
        </div>
      ))
    }
    <div class="actions">
      <a class="btn" href="/about/">About me</a>
    </div>
  </div>

  <div class="stage-col">
    <div class="stage" id="persona-stage" style={`border-color: ${PERSONAS[0].color.main}`}>
      <canvas id="persona-canvas" aria-hidden="true"></canvas>
    </div>
    <div class="stage-ui">
      <div class="dots" role="group" aria-label="페르소나 선택">
        {
          PERSONAS.map((p, i) => (
            <button
              type="button"
              class:list={['dot', { on: i === 0 }]}
              data-persona={p.id}
              data-color={p.color.main}
              data-nav={p.nav}
              aria-label={`${p.name}의 나로 전환`}
              title={`${p.name}의 나`}
            />
          ))
        }
      </div>
      <button
        class="rotate-btn"
        id="persona-rotate"
        type="button"
        aria-label="다음 페르소나로 전환"
        title="다른 나 만나기"
      >
        <svg
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12a9 9 0 1 1-2.64-6.36"></path>
          <polyline points="21 3 21 9 15 9"></polyline>
        </svg>
      </button>
    </div>
    <p class="stage-hint" id="stage-hint">방의 코너를 눌러 다른 나를 만나보세요</p>
  </div>
</section>

<section class="feeds">
  {
    PERSONAS.map((p, i) => (
      <div class="feed" data-persona={p.id} hidden={i !== 0}>
        <div class="feed-head">
          <h2>{p.name}의 글</h2>
          <a class="more" href={sectionHref(p)}>
            전체 보기 →
          </a>
        </div>
        {feeds[p.id].length > 0 ? (
          <div class="grid">
            {feeds[p.id].map((item) => (
              <PostCard item={item} />
            ))}
          </div>
        ) : (
          <p class="empty">아직 글이 없어요. 곧 채워집니다.</p>
        )}
      </div>
    ))
  }
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    gap: 36px;
    padding: 48px 0 36px;
    flex-wrap: wrap;
  }

  .copy-col {
    flex: 1;
    min-width: 280px;
  }

  h1 {
    font-size: 28px;
    margin: 16px 0 8px;
  }

  .role {
    font-size: 15px;
    font-weight: 500;
    margin-bottom: 8px;
  }

  .tagline {
    font-size: 15px;
    color: var(--text-2);
    min-height: 52px;
  }

  .actions {
    margin-top: 20px;
  }

  .stage-col {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    margin: 0 auto;
  }

  /* 방 무대: 원형 링 → 라운드 사각 (design.md §8.1) */
  .stage {
    width: 460px;
    max-width: 100%;
    height: 360px;
    border-radius: 20px;
    background: var(--surface);
    border: 3px solid transparent;
    overflow: hidden;
    transition: border-color 0.4s ease;
    /* 세로 스와이프는 페이지 스크롤로 통과, 탭만 씬이 받는다 (§7.1) */
    touch-action: pan-y;
  }

  .stage canvas {
    width: 100%;
    height: 100%;
    display: block;
  }

  .stage-ui {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .dots {
    display: flex;
    gap: 10px;
  }

  .dot {
    width: 14px;
    height: 14px;
    padding: 0;
    border-radius: 50%;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    cursor: pointer;
    transition: background 0.3s ease, transform 0.15s ease;
  }

  .dot:hover {
    transform: scale(1.25);
  }

  .rotate-btn {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border-strong);
    background: var(--card);
    color: var(--text-2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, transform 0.1s ease;
  }

  .rotate-btn:hover {
    background: var(--surface);
    color: var(--text);
  }

  .rotate-btn:active {
    transform: scale(0.94);
  }

  .rotate-btn svg {
    transition: transform 0.35s ease;
  }

  .rotate-btn:hover svg {
    transform: rotate(90deg);
  }

  .stage-hint {
    font-size: 12.5px;
    color: var(--text-3);
  }

  /* 모바일: 세로 스택 + 캔버스 높이 제한 (design.md §8.2) */
  @media (max-width: 899px) {
    .hero {
      padding-top: 32px;
    }

    .stage-col {
      width: 100%;
    }

    .stage {
      width: 100%;
      height: min(56vw, 320px);
    }
  }

  .feeds {
    padding-bottom: 20px;
  }

  .feed-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .feed-head h2 {
    font-size: 19px;
  }

  .more {
    font-size: 13px;
    color: var(--text-3);
  }

  .more:hover {
    color: var(--text);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 14px;
  }

  .empty {
    font-size: 14px;
    color: var(--text-3);
  }
</style>

<script>
  import { createPersonaRoom } from '../lib/room3d';
  import type { PersonaId } from '../config/personas';

  const stage = document.getElementById('persona-stage')!;
  const canvas = document.getElementById('persona-canvas') as HTMLCanvasElement;
  const rotateBtn = document.getElementById('persona-rotate')!;
  const hint = document.getElementById('stage-hint')!;
  const dots = Array.from(document.querySelectorAll<HTMLElement>('.dot'));
  const navLinks = Array.from(document.querySelectorAll<HTMLElement>('[data-nav-key]'));
  const blocks = Array.from(
    document.querySelectorAll<HTMLElement>('.copy[data-persona], .feed[data-persona]'),
  );
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const personaIds = dots.map((d) => d.dataset.persona as PersonaId);

  // WebGL 미지원 환경에서는 방 없이 텍스트/피드 전환만 동작한다
  let room: ReturnType<typeof createPersonaRoom> | null = null;
  try {
    room = createPersonaRoom(canvas, personaIds[0]);
  } catch (error) {
    console.error('3D 방 초기화 실패:', error);
    stage.hidden = true;
    hint.hidden = true;
  }

  let currentId: PersonaId = personaIds[0];
  let busy = false;

  function syncDOM(id: PersonaId): void {
    const dot = dots.find((d) => d.dataset.persona === id)!;
    for (const block of blocks) block.hidden = block.dataset.persona !== id;
    for (const d of dots) {
      d.classList.toggle('on', d === dot);
      d.style.background = d === dot ? (d.dataset.color ?? '') : '';
    }
    stage.style.borderColor = dot.dataset.color ?? '';
    for (const link of navLinks) {
      link.classList.toggle('active', link.dataset.navKey === dot.dataset.nav);
    }
  }

  /** 단일 진입점: 구역 탭·도트·회전 버튼 모두 여기로 (design.md §7.3) */
  function goToPersona(id: PersonaId): void {
    if (busy || id === currentId) return;
    currentId = id;
    syncDOM(id);
    if (!room) return;
    if (reduceMotion) {
      room.go(id, { instant: true });
      return;
    }
    busy = true;
    room.go(id).finally(() => {
      busy = false;
    });
  }

  room?.onZoneTap(goToPersona);

  rotateBtn.addEventListener('click', () => {
    const next = (personaIds.indexOf(currentId) + 1) % personaIds.length;
    goToPersona(personaIds[next]);
  });

  for (const dot of dots) {
    dot.addEventListener('click', () => goToPersona(dot.dataset.persona as PersonaId));
  }

  syncDOM(currentId);
</script>
