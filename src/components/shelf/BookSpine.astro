---
import type { CollectionEntry } from 'astro:content';
import { paletteFor, spineShape } from '../../lib/shelf';

interface Props {
  entry: CollectionEntry<'shelf'>;
}

const { entry } = Astro.props;
const color = paletteFor(entry.id, entry.data.color);
const shape = spineShape(entry.id);
---

<span
  class="spine"
  style={`width: ${shape.width}px; height: ${shape.height}px; background: ${color.bg}; color: ${color.fg}; ${shape.tilt ? `transform: rotate(${shape.tilt}deg); transform-origin: bottom left;` : ''}`}
>
  {entry.data.title}
</span>

<style>
  .spine {
    writing-mode: vertical-rl;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 1px;
    border-radius: 3px;
    overflow: hidden;
    padding: 8px 0;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
</style>
