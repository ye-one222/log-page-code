---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { getPersona, TYPE_META } from '../../config/personas';
import { formatDate } from '../../lib/posts';

const entries = (await getCollection('playground', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const { color } = getPersona('creator');
---

<Base title="Playground" active="playground">
  <header class="head">
    <h1>Playground</h1>
    <p>실험하고, 만들고, 배우는 놀이터 — 완성보다 과정을 기록합니다</p>
  </header>

  <div class="grid">
    {
      entries.map((entry) => (
        <a class="card project" href={`/playground/${entry.id}/`}>
          <span class="pill" style={`background: ${color.soft}; color: ${color.deep}`}>
            {TYPE_META[entry.data.type].label}
          </span>
          <h2>{entry.data.title}</h2>
          <p class="summary">{entry.data.summary}</p>
          <div class="foot">
            {entry.data.tools.length > 0 && (
              <span class="tools">{entry.data.tools.join(' · ')}</span>
            )}
            <span class="date">{formatDate(entry.data.date)}</span>
          </div>
        </a>
      ))
    }
  </div>
</Base>

<style>
  .head {
    padding: 48px 0 32px;
  }

  h1 {
    font-size: 28px;
  }

  .head p {
    font-size: 15px;
    color: var(--text-2);
    margin-top: 8px;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 16px;
  }

  .project {
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .project:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }

  h2 {
    font-size: 17px;
    margin: 12px 0 8px;
  }

  .summary {
    font-size: 14px;
    color: var(--text-2);
    flex: 1;
  }

  .foot {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    margin-top: 16px;
  }

  .tools {
    font-size: 12px;
    color: var(--text-3);
  }

  .date {
    font-size: 12px;
    color: var(--text-3);
    white-space: nowrap;
  }
</style>
