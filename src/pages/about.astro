---
import Base from '../layouts/Base.astro';
import { SITE } from '../config/site';

/* 아래 배열만 고치면 About이 갱신된다. TODO: 실제 이력으로 교체 */
const career = [
  { period: '2025 — 현재', title: 'AI R&D 연구원', detail: '컴퓨터 비전 연구 (TODO: 소속/프로젝트)' },
  { period: '2022 — 현재', title: '○○대학교 4학년', detail: 'TODO: 전공, 연구실' },
];

const skills = [
  { group: 'Research', items: ['PyTorch', 'Computer Vision', '3D Vision'] },
  { group: 'Creative', items: ['Blender (배우는 중)', '영상 기획/편집'] },
  { group: 'Web', items: ['TypeScript', 'Astro', 'React'] },
];
---

<Base title="About" active="about">
  <section class="head">
    <h1>About</h1>
    <p class="intro">
      낮에는 컴퓨터 비전을 연구하고, 밤에는 만들고 읽고 연주합니다. 연구자와 크리에이터
      사이 어딘가에서 어제보다 나은 오늘을 기록합니다.
    </p>
  </section>

  <section>
    <h2>경력</h2>
    <ol class="timeline">
      {
        career.map((item) => (
          <li>
            <span class="period">{item.period}</span>
            <div>
              <p class="title">{item.title}</p>
              <p class="detail">{item.detail}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section>
    <h2>기술</h2>
    <div class="skills">
      {
        skills.map((s) => (
          <div class="skill-group">
            <p class="group">{s.group}</p>
            <div class="chips">
              {s.items.map((item) => (
                <span class="pill chip">{item}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <section>
    <h2>연락처</h2>
    <p class="contact">
      <a href={`mailto:${SITE.email}`}>{SITE.email}</a> ·
      <a href={SITE.social.github} target="_blank" rel="noopener">GitHub</a> ·
      <a href={SITE.social.linkedin} target="_blank" rel="noopener">LinkedIn</a>
    </p>
  </section>
</Base>

<style>
  .head {
    padding: 48px 0 8px;
  }

  h1 {
    font-size: 28px;
  }

  .intro {
    font-size: 16px;
    color: var(--text-2);
    max-width: 560px;
    margin-top: 12px;
  }

  section {
    margin-bottom: 40px;
  }

  h2 {
    font-size: 19px;
    margin-bottom: 16px;
  }

  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .timeline li {
    display: flex;
    gap: 20px;
  }

  .period {
    font-size: 13px;
    color: var(--text-3);
    min-width: 110px;
    padding-top: 2px;
  }

  .title {
    font-size: 15px;
    font-weight: 600;
  }

  .detail {
    font-size: 14px;
    color: var(--text-2);
  }

  .skills {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .skill-group {
    display: flex;
    gap: 20px;
    align-items: baseline;
  }

  .group {
    font-size: 13px;
    color: var(--text-3);
    min-width: 110px;
  }

  .chips {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .chip {
    background: var(--surface);
    color: var(--text-2);
  }

  .contact {
    font-size: 14px;
  }

  .contact a {
    color: var(--text-2);
    text-decoration: underline;
  }

  .contact a:hover {
    color: var(--text);
  }
</style>
